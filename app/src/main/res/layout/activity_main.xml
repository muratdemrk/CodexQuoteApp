<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ui.MainActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:contentInsetStartWithNavigation="0dp"
                android:title="@string/app_name"
                android:titleTextColor="?attr/colorOnSurface" />
        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingStart="@dimen/screen_padding"
            android:paddingTop="10dp"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingBottom="@dimen/screen_padding"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressIndicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/content_spacing"
                    android:visibility="gone"
                    android:indeterminate="true" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_quote"
                    app:tint="?attr/colorPrimary" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/quoteCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/content_spacing"
                    android:contentDescription="@string/quote_card_content_description"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="@dimen/card_radius"
                    app:cardElevation="3dp"
                    app:strokeColor="?attr/colorOutline"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/screen_padding">

                        <TextView
                            android:id="@+id/textQuote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:lineSpacingExtra="6dp"
                            android:text="@string/loading_quote"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/quote_text_size"
                            tools:text="Başarı, her gün tekrarlanan küçük çabaların toplamıdır." />

                        <View
                            android:layout_width="48dp"
                            android:layout_height="3dp"
                            android:layout_marginTop="@dimen/content_spacing"
                            android:background="?attr/colorPrimary" />

                        <TextView
                            android:id="@+id/textAuthor"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/content_spacing"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/body_text_size"
                            tools:text="Yazar: Albert Einstein" />

                        <TextView
                            android:id="@+id/textCategory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/small_spacing"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="@dimen/body_text_size"
                            tools:text="Kategori: Bilgelik" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonTranslate"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/content_spacing"
                    android:text="@string/translate_to_turkish"
                    app:cornerRadius="@dimen/button_corner_radius"
                    app:icon="@drawable/ic_translate"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconTint="@null" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/content_spacing"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonFavorite"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/small_spacing"
                        android:layout_weight="1"
                        android:text="@string/favorite_action_add"
                        app:cornerRadius="@dimen/button_corner_radius"
                        app:icon="@drawable/ic_favorite_outline"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconTint="@null" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonRefresh"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/small_spacing"
                        android:layout_weight="1"
                        android:text="@string/refresh_quote"
                        app:cornerRadius="@dimen/button_corner_radius"
                        app:icon="@drawable/ic_refresh"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconTint="@null" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header_main"
        app:itemIconTint="?attr/colorOnSurfaceVariant"
        app:itemTextColor="?attr/colorOnSurface"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
